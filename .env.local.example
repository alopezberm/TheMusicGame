# Spotify Developer Dashboard (https://developer.spotify.com/dashboard)
# Create an app there, then copy its Client ID and Client Secret here.
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# Generate with: npx auth secret
AUTH_SECRET=

# http://localhost:3000 in development; your Vercel URL in production.
# Whatever you set here + "/api/auth/callback/spotify" must be added as a
# Redirect URI in the Spotify app settings.
AUTH_URL=http://localhost:3000
